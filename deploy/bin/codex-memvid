#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
context_bin="$script_dir/memvid-context"
if [[ ! -x "$context_bin" ]]; then
  context_bin="$(command -v memvid-context 2>/dev/null)" || {
    echo "codex-memvid: unable to find memvid-context" >&2
    exit 127
  }
fi

find_agent() {
  local name="$1"
  local candidate resolved wrapper
  local -a path_dirs
  local IFS=:
  wrapper="$(realpath -m "$script_dir/$name-memvid" 2>/dev/null || printf '%s/%s-memvid' "$script_dir" "$name")"
  read -r -a path_dirs <<< "${PATH:-}"
  for dir in "${path_dirs[@]}"; do
    [[ -n "$dir" ]] || dir=.
    candidate="$dir/$name"
    [[ -x "$candidate" ]] || continue
    resolved="$(realpath -m "$candidate" 2>/dev/null || printf '%s' "$candidate")"
    [[ "$resolved" != "$wrapper" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

agent_bin="${MEMVID_CODEX_BIN:-}"
if [[ -z "$agent_bin" ]]; then
  agent_bin="$(find_agent codex)" || {
    echo "codex-memvid: unable to find real codex command in PATH" >&2
    exit 127
  }
fi

context_err="$(mktemp "${TMPDIR:-/tmp}/memvid-context-codex.XXXXXX")"
if ! context="$(MEMVID_AGENT=codex "$context_bin" --agent codex 2>"$context_err")"; then
  context="# Memvid Startup Context

- agent: \`codex\`
- librarian: \`fallback\`
- warning: \`memvid-context failed; launching agent without recalled memory\`

## Operating Rules

Do not use agent-native memory tools, memory caches, learned profiles, or cross-session recall for project facts, architecture, conventions, decisions, handoffs, or task state. Durable memory writes go only through atomic Markdown files in \`/var/lib/memvid/queue\`.

## memvid-context stderr

\`\`\`text
$(sed -n '1,20p' "$context_err")
\`\`\`"
fi
rm -f "$context_err"

if [[ "$#" -eq 0 ]]; then
  exec "$agent_bin" "$context"
fi

codex_args=()
prompt_parts=()
seen_separator=0
for arg in "$@"; do
  if [[ "$seen_separator" -eq 0 && "$arg" == "--" ]]; then
    seen_separator=1
    continue
  fi
  if [[ "$seen_separator" -eq 0 ]]; then
    codex_args+=("$arg")
  else
    prompt_parts+=("$arg")
  fi
done

if [[ "$seen_separator" -eq 0 ]]; then
  prompt="$*"
  exec "$agent_bin" "$context

User request:
$prompt"
fi

prompt="${prompt_parts[*]}"
exec "$agent_bin" "${codex_args[@]}" "$context

User request:
$prompt"
