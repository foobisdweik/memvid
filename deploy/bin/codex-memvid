#!/usr/bin/env bash
set -euo pipefail

context="$(MEMVID_AGENT=codex memvid-context --agent codex)"
if [[ "$#" -eq 0 ]]; then
  exec codex "$context"
fi

codex_args=()
prompt_parts=()
seen_separator=0
for arg in "$@"; do
  if [[ "$seen_separator" -eq 0 && "$arg" == "--" ]]; then
    seen_separator=1
    continue
  fi
  if [[ "$seen_separator" -eq 0 ]]; then
    codex_args+=("$arg")
  else
    prompt_parts+=("$arg")
  fi
done

if [[ "$seen_separator" -eq 0 ]]; then
  prompt="$*"
  exec codex "$context

User request:
$prompt"
fi

prompt="${prompt_parts[*]}"
exec codex "${codex_args[@]}" "$context

User request:
$prompt"
