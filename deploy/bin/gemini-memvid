#!/usr/bin/env bash
set -euo pipefail

context="$(MEMVID_AGENT=gemini memvid-context --agent gemini)"
if [[ "$#" -eq 0 ]]; then
  exec gemini --prompt-interactive "$context"
fi

gemini_args=()
prompt_parts=()
seen_separator=0
for arg in "$@"; do
  if [[ "$seen_separator" -eq 0 && "$arg" == "--" ]]; then
    seen_separator=1
    continue
  fi
  if [[ "$seen_separator" -eq 0 ]]; then
    gemini_args+=("$arg")
  else
    prompt_parts+=("$arg")
  fi
done

if [[ "$seen_separator" -eq 0 ]]; then
  prompt="$*"
  exec gemini --prompt-interactive "$context

User request:
$prompt"
fi

prompt="${prompt_parts[*]}"
exec gemini "${gemini_args[@]}" --prompt-interactive "$context

User request:
$prompt"
