#!/usr/bin/env bash
# gemini-memvid: launch the real `gemini` CLI with the current project shard injected.
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
context_bin="$script_dir/memvid-context"
if [[ ! -x "$context_bin" ]]; then
  context_bin="$(command -v memvid-context 2>/dev/null)" || {
    echo "gemini-memvid: unable to find memvid-context" >&2
    exit 127
  }
fi

find_agent() {
  local name="$1" candidate resolved wrapper
  local -a path_dirs
  local IFS=:
  wrapper="$(realpath -m "$script_dir/$name-memvid" 2>/dev/null || printf '%s/%s-memvid' "$script_dir" "$name")"
  read -r -a path_dirs <<< "${PATH:-}"
  for dir in "${path_dirs[@]}"; do
    [[ -n "$dir" ]] || dir=.
    candidate="$dir/$name"
    [[ -x "$candidate" ]] || continue
    resolved="$(realpath -m "$candidate" 2>/dev/null || printf '%s' "$candidate")"
    [[ "$resolved" != "$wrapper" ]] || continue
    printf '%s\n' "$candidate"
    return 0
  done
  return 1
}

agent_bin="${MEMVID_GEMINI_BIN:-}"
if [[ -z "$agent_bin" ]]; then
  agent_bin="$(find_agent gemini)" || {
    echo "gemini-memvid: unable to find real gemini command in PATH" >&2
    exit 127
  }
fi

project="${MEMVID_PROJECT:-$(basename -- "$PWD")}"
context="$(MEMVID_AGENT=gemini "$context_bin" --project "$project" 2>/dev/null)" || context="# Memvid Startup Context

- project: \`$project\`
- shard: \`unavailable\`
- note: memvid-context failed; launching agent without recalled context."

if [[ "$#" -eq 0 ]]; then
  exec "$agent_bin" "$context"
fi

agent_args=()
prompt_parts=()
seen_separator=0
for arg in "$@"; do
  if [[ "$seen_separator" -eq 0 && "$arg" == "--" ]]; then
    seen_separator=1
    continue
  fi
  if [[ "$seen_separator" -eq 0 ]]; then
    agent_args+=("$arg")
  else
    prompt_parts+=("$arg")
  fi
done

if [[ "$seen_separator" -eq 0 ]]; then
  prompt="$*"
  exec "$agent_bin" "$context

User request:
$prompt"
fi

prompt="${prompt_parts[*]}"
exec "$agent_bin" "${agent_args[@]}" "$context

User request:
$prompt"
