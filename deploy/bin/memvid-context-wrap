#!/usr/bin/env bash
set -euo pipefail

agent="${MEMVID_AGENT:-agent}"
project="${MEMVID_PROJECT:-}"
budget="${MEMVID_CONTEXT_BUDGET_TOKENS:-4000}"
tmp="$(mktemp "${TMPDIR:-/tmp}/memvid-context-${agent}.XXXXXX.md")"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
context_bin="$script_dir/memvid-context"
if [[ ! -x "$context_bin" ]]; then
  context_bin="$(command -v memvid-context 2>/dev/null)" || {
    echo "memvid-context-wrap: unable to find memvid-context" >&2
    exit 127
  }
fi

args=(--agent "$agent" --budget-tokens "$budget")
if [[ -n "$project" ]]; then
  args+=(--project "$project")
fi

if ! "$context_bin" "${args[@]}" > "$tmp"; then
  cat > "$tmp" <<EOF
# Memvid Startup Context

- agent: \`$agent\`
- librarian: \`fallback\`
- warning: \`memvid-context failed; launching command without recalled memory\`

## Operating Rules

Do not use agent-native memory tools, memory caches, learned profiles, or cross-session recall for project facts, architecture, conventions, decisions, handoffs, or task state. Durable memory writes go only through atomic Markdown files in \`/var/lib/memvid/queue\`.
EOF
fi
chmod 0600 "$tmp"
export MEMVID_STARTUP_CONTEXT_FILE="$tmp"
export MEMVID_STARTUP_CONTEXT="$(cat "$tmp")"

if [[ "$#" -eq 0 ]]; then
  cat "$tmp"
  exit 0
fi

exec "$@"
